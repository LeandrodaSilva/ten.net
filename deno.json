{
  "name": "@leproj/tennet",
  "version": "0.3.0",
  "description": "A minimalist Deno web microframework with file-based routing, HTML templating, nested layouts, and a plugin system",
  "license": "MIT",
  "exports": {
    ".": "./src/mod.ts",
    "./cli": "./src/cli.ts",
    "./build": "./src/build/build.ts",
    "./build/manifest": "./src/build/manifest.ts",
    "./build/crypto": "./src/build/crypto.ts"
  },
  "tasks": {
    "dev": "deno run -P --inspect --unstable-bundle --unstable-raw-imports --watch demo.ts",
    "test": "deno test --parallel --allow-all --unstable-raw-imports --unstable-bundle",
    "coverage": "deno test --no-check --coverage=coverage --allow-all --unstable-raw-imports --unstable-bundle",
    "fmt": "deno fmt",
    "lint": "deno lint --unstable-raw-imports",
    "check": "deno check  **/*.ts --unstable-raw-imports",
    "bench": "deno bench --allow-all --unstable-raw-imports --unstable-bundle --json src/bench/ | deno run --allow-all src/bench/_history.ts && deno fmt README.md",
    "bench:run": "deno bench --allow-all --unstable-raw-imports --unstable-bundle src/bench/",
    "bench:check": "deno run --allow-all src/bench/_check_thresholds.ts",
    "build": "deno run --allow-read --allow-write --allow-env --allow-run --unstable-bundle src/build/buildCommand.ts"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.14",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/async": "jsr:@std/async@^1.0.14",
    "@std/testing": "jsr:@std/testing@^1.0.15",
    "deno-fs": "jsr:@std/fs@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.2",
    "@deno-assert": "https://deno.land/std@0.208.0/assert/mod.ts",
    "@std/cli": "jsr:@std/cli@^1.0.0",
    "@deno-walk": "jsr:@std/fs@1/walk",
    "react": "npm:react@^19.1.1",
    "react-dom": "npm:react-dom@^19.1.1",
    "react-dom/server": "npm:react-dom@^19.1.1/server",
    "@types/react": "npm:@types/react@^19.1.1",
    "@types/react-dom": "npm:@types/react-dom@^19.1.1"
  },
  "exclude": [
    ".git",
    "node_modules",
    "dist",
    "build",
    "coverage"
  ],
  "permissions": {
    "default": {
      "read": true,
      "write": true,
      "env": true,
      "net": true
    }
  },
  "publish": {
    "include": [
      "src/",
      "README.md",
      "LICENSE",
      "deno.json"
    ]
  }
}
