{
  "name": "@leproj/tennet",
  "version": "0.10.0",
  "description": "A minimalist Deno web microframework with file-based routing, HTML templating, nested layouts, and a plugin system",
  "license": "MIT",
  "exports": {
    ".": "./packages/core/src/mod.ts",
    "./cli": "./packages/core/src/cli.ts",
    "./build": "./packages/core/src/build/build.ts",
    "./build/manifest": "./packages/core/src/build/manifest.ts",
    "./build/crypto": "./packages/core/src/build/crypto.ts",
    "./assets/favicon": "./packages/core/src/assets/faviconData.ts",
    "./admin": "./packages/admin/src/mod.ts",
    "./widgets": "./packages/widgets/src/mod.ts"
  },
  "tasks": {
    "dev": "deno run -P --inspect --unstable-kv --unstable-raw-imports --watch app/demo.ts",
    "test": "deno test --parallel --allow-all --unstable-raw-imports --unstable-kv",
    "coverage": "deno test --no-check --coverage=coverage --allow-all --unstable-raw-imports --unstable-kv",
    "fmt": "deno fmt",
    "lint": "deno lint --unstable-raw-imports",
    "check": "deno check  **/*.ts --unstable-raw-imports",
    "bench": "deno bench --allow-all --unstable-raw-imports --json src/bench/ | deno run --allow-all src/bench/_history.ts && deno fmt README.md",
    "bench:run": "deno bench --allow-all --unstable-raw-imports src/bench/",
    "bench:check": "deno run --allow-all src/bench/_check_thresholds.ts",
    "build": "deno run --allow-read --allow-write --allow-env --allow-run packages/core/src/build/buildCommand.ts"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.14",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/async": "jsr:@std/async@^1.0.14",
    "@std/testing": "jsr:@std/testing@^1.0.15",
    "deno-fs": "jsr:@std/fs@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.2",
    "@leproj/tennet": "./packages/core/src/mod.ts",
    "@leproj/tennet-widgets": "./packages/widgets/src/mod.ts",
    "@deno-assert": "https://deno.land/std@0.208.0/assert/mod.ts",
    "@std/cli": "jsr:@std/cli@^1.0.0",
    "@deno-walk": "jsr:@std/fs@1/walk",
    "@deno/emit": "jsr:@deno/emit@^0.46",
    "react": "npm:react@^19.1.1",
    "react-dom": "npm:react-dom@^19.1.1",
    "react-dom/server": "npm:react-dom@^19.1.1/server",
    "@types/react": "npm:@types/react@^19.1.1",
    "@types/react-dom": "npm:@types/react-dom@^19.1.1",
    "puppeteer": "https://deno.land/x/puppeteer@16.2.0/mod.ts"
  },
  "exclude": [
    ".git",
    ".claude/agents/frontend-dev-agent-templates",
    ".claude/worktrees",
    "node_modules",
    "dist",
    "build",
    "coverage"
  ],
  "permissions": {
    "default": {
      "read": true,
      "write": true,
      "env": true,
      "net": true
    }
  }
}
